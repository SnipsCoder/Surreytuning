diff --git a/app/Services/FileStorageService.php b/app/Services/FileStorageService.php
--- a/app/Services/FileStorageService.php
+++ b/app/Services/FileStorageService.php
@@ -85,15 +85,17 @@ public function validateFile(UploadedFile $file): void
             throw new InvalidArgumentException('File exceeds the maximum allowed size of 50MB.');
         }
 
-        $extension = strtolower($file->getClientOriginalExtension());
-        if (! in_array($extension, $this->getAllowedExtensions(), true)) {
-            throw new InvalidArgumentException('File type not allowed.');
-        }
+        // We do NOT gate on file extension. Tune files come from dozens of tools,
+        // each inventing its own extension (.mpc, .kess, .ktag, .ori, .bin, ...),
+        // and the upload page promises "any binary tune file accepted". Gating on
+        // a fixed extension list would reject legitimate files (this is exactly
+        // what broke .MPC uploads). Content is what matters, enforced by the MIME
+        // sniff below.
 
         // Server-side MIME sniffing (not just the client-supplied extension). ECU
         // binaries resolve to application/octet-stream; some tools emit text/plain
         // for ASCII hex dumps. Anything else (e.g. a disguised PDF/EXE/script)
-        // is rejected even if it carries an allowed extension.
+        // is rejected on content.
         $mimeType = $file->getMimeType();
         if ($mimeType !== null && ! in_array($mimeType, $this->getAllowedMimeTypes(), true)) {
             throw new InvalidArgumentException('File content does not match an allowed type.');
