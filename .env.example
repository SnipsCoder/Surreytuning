APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — local dev writes to the laravel.log file (MAIL_MAILER=log).
# In PRODUCTION use an authenticated relay (SMTP, SES, Postmark, or Resend) so
# transactional email actually delivers. See docs/email-deliverability.md.
# SPF, DKIM and DMARC DNS records for MAIL_FROM_ADDRESS's domain are the
# operator's responsibility and are required for reliable inbox placement.
# Verify credentials + From address after deploy with: php artisan mail:test you@example.com
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Production mail example (SMTP relay) ---------------------------------
# MAIL_MAILER=smtp
# MAIL_SCHEME=tls
# MAIL_HOST=smtp.your-provider.com
# MAIL_PORT=587
# MAIL_USERNAME=your-smtp-username
# MAIL_PASSWORD=your-smtp-password
# MAIL_FROM_ADDRESS="no-reply@surreytuning.co.uk"
# MAIL_FROM_NAME="Surrey Tuning Services"
#
# --- Production mail example (Amazon SES) ---------------------------------
# MAIL_MAILER=ses
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_DEFAULT_REGION below are reused by SES.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudflare R2 — primary bucket for tenant file uploads (private; signed URLs only).
FILE_STORAGE_DISK=r2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_URL=
R2_ENDPOINT=

# Automated backups (spatie/laravel-backup → separate PRIVATE R2 bucket).
# Leave the R2_BACKUP_* credentials blank to reuse the primary R2 keys above;
# set them to a dedicated key/bucket so a compromised app credential can't
# reach the backups. See docs/backups.md.
BACKUP_NAME=surreytuning-central
BACKUP_NOTIFICATION_EMAIL=
# Encrypts every backup archive at rest. Set a strong value in production and
# store it somewhere OTHER than the backup bucket — without it, restores fail.
BACKUP_ARCHIVE_PASSWORD=
R2_BACKUP_ACCESS_KEY_ID=
R2_BACKUP_SECRET_ACCESS_KEY=
R2_BACKUP_BUCKET=
R2_BACKUP_ENDPOINT=

# Error monitoring (Sentry). Leave DSN empty to disable reporting (e.g. local/testing).
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_SEND_DEFAULT_PII=false

# GDPR / data protection (see docs and config/gdpr.php).
# Disk used to write data-subject export archives. Default `local`; use a
# private disk in production so exports are not publicly reachable.
GDPR_EXPORT_DISK=local
# How long rejected dealer applications are retained before pruning (days).
GDPR_RETAIN_REJECTED_APPLICATIONS_DAYS=365
# Contact address shown on the privacy policy for data-subject requests.
GDPR_PRIVACY_CONTACT_EMAIL=

# Deep health check (/healthz). Optional shared secret — when set, callers must
# pass ?token=<value> or the endpoint returns 404. Leave blank in local dev.
HEALTH_CHECK_TOKEN=

VITE_APP_NAME="${APP_NAME}"
